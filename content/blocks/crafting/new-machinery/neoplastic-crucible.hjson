    {
      type: DrawDefault
    }
    {
      type: DrawWarmupRegion
    }
    # Re-added the flame layer
    {
      type: DrawFlame
      flameColor: ffc999
      flameRadius: 5.5
      flameRadiusMag: 2.5
    }
  ]
}

craftEffect: smeltsmoke
ambientSound: loopSmelter

requirements: [
  surge-alloy/140
  plastanium/120
  neoplastic-alloy/120
