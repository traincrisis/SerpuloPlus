size: 4
hasPower: true
hasItems: true
hasLiquids: true
itemCapacity: 40
liquidCapacity: 130

# 1 second = 60 ticks
craftTime: 90

consumes: {
  power: 4.66666666667
  items: [
    surge-alloy/5
    graphite/10
    phase-fabric/5
  ]
  liquids: [
    neoplasm/0.33333333333
    water/0.5
  ]
}

