type: GenericCrafter
name: Slag Decapsulator
description: Empties liquid capsules of slag.
size: 2
hasPower: true
hasItems: true
hasLiquids: true
itemCapacity: 10
liquidCapacity: 60

consumes: {
  power: 0.5
  items: [
    slag-capsule/1
  ]
}

craftTime: 45
outputLiquid: slag/0.16666666666
outputItem: liquid-capsule/1

drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawRegion
      suffix: -bottom
    }
    {
      type: DrawLiquidTile
      drawLiquid: slag
    }
    {
      type: DrawDefault
    }
  ]
}

# The classic Serpulo smoke effect
ambientSound: loopCultivator

requirements: [
  metaglass/160
  graphite/105
  titanium/30
  silicon/105
]

category: liquid
research: slag-encapsulator
