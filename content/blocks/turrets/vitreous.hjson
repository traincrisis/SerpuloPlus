    type: LaserBulletType
    damage: 132
    length: 152
    width: 12
    # Your specific neon green-cyan: 7cff8e
    colors: [7cff8e, b0ffc6, ffffff]
    status: burning
    statusDuration: 600
    makeFire: true
  }
}

